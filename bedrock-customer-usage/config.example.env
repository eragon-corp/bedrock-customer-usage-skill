# Copy to one of:
#   ./bedrock-customer-usage.env
#   ~/.config/bedrock-customer-usage/config.env
#   bedrock-customer-usage/config.env
#
# Do not put real access keys in this file if it will be committed.

# Shared customer scope
export BEDROCK_USAGE_AWS_ACCOUNT_ID=123456789012
export BEDROCK_USAGE_AWS_REGION=ap-southeast-1
export BEDROCK_USAGE_BUDGET_NAME='Customer Bedrock monthly budget'
export BEDROCK_USAGE_CUSTOMER_PATH=/bedrock-customers/customer/
# Optional: enables scoped Cost Explorer totals.
# export BEDROCK_USAGE_BILLING_VIEW_ARN=arn:aws:billing::123456789012:billingview/custom-...

# Optional: enables aggregate token usage from CloudWatch Logs model
# invocation logs. The script prints aggregates only, not raw prompt/response logs.
# export BEDROCK_USAGE_INVOCATION_LOG_GROUP=/aws/bedrock/model-invocations
# export BEDROCK_USAGE_INVOCATION_LOG_LIMIT=100
# export BEDROCK_USAGE_INVOCATION_LOG_QUERY_TIMEOUT_SECONDS=60

# Key creation defaults
export BEDROCK_KEY_CUSTOMER_PATH=/bedrock-customers/customer/
export BEDROCK_KEY_OWNER=customer-owner
export BEDROCK_KEY_PURPOSE=customer-purpose
export BEDROCK_KEY_REGION=ap-southeast-1
# Optional: model used by create-key and smoke-test verification.
export BEDROCK_KEY_VERIFY_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# Optional: default is access-key. Set bearer only when callers need
# AWS_BEARER_TOKEN_BEDROCK instead of AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY.
# export BEDROCK_KEY_CREDENTIAL_TYPE=access-key
# export BEDROCK_KEY_BEARER_TOKEN_DAYS=90

# Optional: default create-key path uses an inline Bedrock runtime policy.
# Set these only if your account requires a managed runtime policy or boundary.
# export BEDROCK_KEY_RUNTIME_POLICY_ARN=arn:aws:iam::123456789012:policy/BedrockCustomerRuntime
# export BEDROCK_KEY_BOUNDARY_POLICY_ARN=arn:aws:iam::123456789012:policy/BedrockCustomerBoundary
# export BEDROCK_KEY_RUNTIME_POLICY_JSON=/secure/path/bedrock-runtime-policy.json
